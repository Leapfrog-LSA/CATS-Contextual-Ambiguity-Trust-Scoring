CATS_API_KEY=change-me-strong-random-key
CATS_API_KEY_PREV=
# Optional multi-tenant keys: CSV of "key:tenant" pairs. Unlisted keys
# (CATS_API_KEY/_PREV) resolve to the "default" tenant.
# CATS_API_KEYS=keyA:tenant-a,keyB:tenant-b
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

DATABASE_URL=postgresql+asyncpg://cats:cats@localhost:5432/cats
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_POOL_PRE_PING=true

REDIS_URL=redis://localhost:6379/0
REDIS_RATE_LIMIT_MAX=30
REDIS_RATE_LIMIT_WINDOW_SECONDS=60
REDIS_VALIDATOR_TTL_SECONDS=120

AUDIT_ENCRYPTION_KEY=change-me-32-bytes-base64-encoded=
AUDIT_RETENTION_DAYS=90

SPACY_MODEL=it_core_news_lg
NLP_GAMING_MIN_TOKENS=10

# Optional: path to a calibrated weights file produced by `make calibrate`
# (see docs/calibration.md). Falls back to static estimates when unset.
CATS_WEIGHTS_FILE=

ENVIRONMENT=production
LOG_LEVEL=INFO
CORS_ORIGINS=
